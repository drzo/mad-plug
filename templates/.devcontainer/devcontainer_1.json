{
    "name": "Plan 9 Development",
    "build": {
        "dockerfile": "Dockerfile",
        "args": {
            "PLAN9": "/usr/local/plan9",
            "GRID_NODES": "3",
            "ENABLE_GUI": "true"
        }
    },
    "features": {
        "ghcr.io/devcontainers/features/common-utils:2": {
            "installZsh": false,
            "installOhMyZsh": false,
            "username": "glenda"
        },
        "ghcr.io/devcontainers/features/docker-in-docker:2": {
            "dockerDashComposeVersion": "v2"
        },
        "ghcr.io/devcontainers/features/git:1": {},
        "ghcr.io/devcontainers/features/github-cli:1": {},
        "ghcr.io/devcontainers/features/python:1": {
            "version": "3.11"
        }
    },
    "containerEnv": {
        "PLAN9": "/usr/local/plan9",
        "PATH": "/usr/local/plan9/bin:${containerEnv:PATH}",
        "PLAN9_GRID_NODES": "3",
        "PLAN9_9P_PORT": "564",
        "DISPLAY": ":0"
    },
    "forwardPorts": [564, 565, 566, 8080, 9090],
    "portsAttributes": {
        "564": { "label": "9P2000 — Auth/Registry", "protocol": "tcp" },
        "565": { "label": "9P2000 — CPU 1", "protocol": "tcp" },
        "566": { "label": "9P2000 — CPU 2", "protocol": "tcp" },
        "8080": { "label": "Plan 9 Web Interface", "protocol": "http" },
        "9090": { "label": "Grid Monitor", "protocol": "http" }
    },
    "mounts": [
        "source=plan9-devcontainer-home,target=/home/glenda,type=volume",
        "source=plan9-grid-data,target=/var/plan9/grid,type=volume"
    ],
    "customizations": {
        "vscode": {
            "settings": {
                "editor.tabSize": 8,
                "editor.insertSpaces": false,
                "files.associations": {
                    "*.c": "c",
                    "*.h": "c",
                    "mkfile": "makefile",
                    "mkconfig": "makefile"
                },
                "files.trimTrailingWhitespace": true
            },
            "extensions": [
                "ms-vscode.cpptools",
                "ms-vscode.makefile-tools",
                "ms-azuretools.vscode-docker",
                "mhutchie.git-graph",
                "usernamehw.errorlens"
            ]
        }
    },
    "postCreateCommand": "bash .devcontainer/scripts/post-create.sh",
    "postStartCommand": "bash .devcontainer/scripts/post-start.sh",
    "remoteUser": "glenda",
    "hostRequirements": {
        "cpus": 4,
        "memory": "8gb",
        "storage": "32gb"
    }
}
