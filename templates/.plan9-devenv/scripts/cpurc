#!/bin/bash
# =============================================================================
# Plan9Cog Cognitive DevKernel — cpurc (post-create lifecycle script)
# Runs once after container creation.
# Plan 9 analogue of Inferno's post-create.sh.
# =============================================================================

set -e

echo "========================================"
echo "  Plan9Cog DevKernel — cpurc"
echo "  Initializing development environment"
echo "========================================"

# --- 1. Verify plan9port installation ---
echo ""
echo "[1/6] Verifying plan9port installation..."

PLAN9="${PLAN9:-/usr/local/plan9}"

if [ -d "$PLAN9" ] && [ -x "$PLAN9/bin/9" ]; then
    echo "  + plan9port found at $PLAN9"
    echo "  + 9 command: $($PLAN9/bin/9 echo ok)"
else
    echo "  X plan9port not found at $PLAN9"
    echo "    Install from: https://github.com/9fans/plan9port"
    exit 1
fi

# Check for key tools
for tool in mk acme sam rc; do
    if [ -x "$PLAN9/bin/$tool" ] || [ -x "$PLAN9/bin/9" ]; then
        echo "  + $tool available"
    else
        echo "  ! $tool not found"
    fi
done

# --- 2. Verify QEMU installation ---
echo ""
echo "[2/6] Verifying QEMU installation..."

if command -v qemu-system-x86_64 &>/dev/null; then
    QEMU_VERSION=$(qemu-system-x86_64 --version | head -1)
    echo "  + $QEMU_VERSION"
else
    echo "  ! QEMU not found — Plan 9 VM execution unavailable"
    echo "    Install with: apt-get install qemu-system-x86"
fi

# --- 3. Create workspace structure ---
echo ""
echo "[3/6] Creating workspace structure..."

mkdir -p /workspace/src
mkdir -p /workspace/bin
mkdir -p /workspace/lib

echo "  + /workspace/src — Source code"
echo "  + /workspace/bin — Compiled binaries"
echo "  + /workspace/lib — Libraries"

# --- 4. Set up cognitive namespace directories ---
echo ""
echo "[4/6] Setting up cognitive namespace..."

COGNITIVE_PATHS=(
    "/cognitive/atomspace/atoms"
    "/cognitive/atomspace/types"
    "/cognitive/atomspace/indices"
    "/cognitive/inference/rules"
    "/cognitive/inference/queue"
    "/cognitive/inference/results"
    "/cognitive/attention/bank"
    "/cognitive/attention/agents"
    "/cognitive/learning/populations"
    "/cognitive/learning/fitness"
    "/cognitive/temporal/levels"
    "/cognitive/temporal/phases"
    "/cognitive/autognosis/images"
    "/cognitive/autognosis/insights"
    "/cognitive/autognosis/metrics"
)

for ns_path in "${COGNITIVE_PATHS[@]}"; do
    mkdir -p "$ns_path" 2>/dev/null || true
    echo "  + $ns_path"
done

# --- 5. Install CLI tools ---
echo ""
echo "[5/6] Installing CLI tools..."

# plan9-grid CLI
cat > /usr/local/bin/plan9-grid << 'GRIDEOF'
#!/bin/bash
# Plan 9 CPU Server Grid Manager
case "$1" in
    start)
        NODES="${3:-3}"
        echo "Starting Plan 9 CPU server grid with $NODES nodes..."
        if [ -f grid-compose.yml ]; then
            docker compose -f grid-compose.yml up -d --scale plan9-cpu=$((NODES-1))
        else
            echo "grid-compose.yml not found. Copy from skill templates."
        fi
        ;;
    stop)
        echo "Stopping Plan 9 CPU server grid..."
        docker compose -f grid-compose.yml down 2>/dev/null || true
        ;;
    status)
        echo "Plan 9 CPU Server Grid Status:"
        docker compose -f grid-compose.yml ps 2>/dev/null || echo "Grid not running"
        ;;
    connect)
        echo "Connecting to node $2 via 9P2000..."
        socat - TCP:localhost:$((564 + ${2:-0}))
        ;;
    deploy)
        echo "Deploying $2 to all CPU servers..."
        # In production: use import/exportfs to distribute
        ;;
    logs)
        docker compose -f grid-compose.yml logs ${2:---tail=50} 2>/dev/null
        ;;
    *)
        echo "Usage: plan9-grid {start|stop|status|connect|deploy|logs} [args]"
        ;;
esac
GRIDEOF
chmod +x /usr/local/bin/plan9-grid

# plan9-build CLI
cat > /usr/local/bin/plan9-build << 'BUILDEOF'
#!/bin/bash
# Plan 9 C Build Tool (wraps plan9port mk/6c/6l)
PLAN9="${PLAN9:-/usr/local/plan9}"
case "$1" in
    compile)
        SRC="$2"
        BASE="${SRC%.c}"
        echo "Compiling $SRC with Plan 9 C compiler..."
        $PLAN9/bin/9 6c -o "${BASE}.6" "$SRC" && \
        $PLAN9/bin/9 6l -o "${BASE}.out" "${BASE}.6" && \
        echo "  + Output: ${BASE}.out"
        ;;
    run)
        SRC="$2"
        BASE="${SRC%.c}"
        $PLAN9/bin/9 6c -o "${BASE}.6" "$SRC" && \
        $PLAN9/bin/9 6l -o "${BASE}.out" "${BASE}.6" && \
        "./${BASE}.out"
        ;;
    check)
        echo "Type-checking $2..."
        $PLAN9/bin/9 6c -w "$2" 2>&1
        ;;
    clean)
        echo "Cleaning build artifacts..."
        rm -f *.6 *.out
        ;;
    *)
        echo "Usage: plan9-build {compile|run|check|clean} [file.c]"
        ;;
esac
BUILDEOF
chmod +x /usr/local/bin/plan9-build

echo "  + plan9-grid installed"
echo "  + plan9-build installed"

# --- 6. Verification summary ---
echo ""
echo "[6/6] Verification summary..."
echo ""
echo "  Plan 9 Cognitive DevKernel initialized."
echo "  PLAN9=$PLAN9"
echo "  Cognitive namespace: /cognitive/ (15 paths)"
echo "  CLI tools: plan9-grid, plan9-build"
echo ""
echo "  Quick start:"
echo "    plan9-build compile src/cogkernel.c"
echo "    plan9-grid start"
echo ""
echo "========================================"
echo "  cpurc complete"
echo "========================================"
