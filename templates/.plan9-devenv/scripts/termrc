#!/bin/bash
# =============================================================================
# Plan9Cog Cognitive DevKernel — termrc (post-start lifecycle script)
# Runs on every container start.
# Plan 9 analogue of Inferno's post-start.sh.
# =============================================================================

echo "Plan9Cog DevKernel — termrc"

# Verify PATH includes plan9port
PLAN9="${PLAN9:-/usr/local/plan9}"
if [[ ":$PATH:" != *":$PLAN9/bin:"* ]]; then
    export PATH="$PLAN9/bin:$PATH"
    echo "  + Added $PLAN9/bin to PATH"
fi

# Verify Docker network for grid
if command -v docker &>/dev/null; then
    docker network inspect plan9-net &>/dev/null 2>&1 || \
        docker network create --subnet=172.29.0.0/16 plan9-net 2>/dev/null
    echo "  + plan9-net network verified"
fi

# Verify cognitive namespace
NS_COUNT=0
for ns in /cognitive/atomspace /cognitive/inference /cognitive/attention \
          /cognitive/learning /cognitive/temporal /cognitive/autognosis; do
    [ -d "$ns" ] && NS_COUNT=$((NS_COUNT + 1))
done
echo "  + Cognitive namespace: $NS_COUNT/6 service groups mounted"

# Display status
echo ""
echo "  Plan9Cog ready."
echo "  plan9-grid status  — Check grid"
echo "  plan9-build --help — Build tools"
echo ""
