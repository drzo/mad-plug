<$PLAN9/src/mkhdr

TARG=\
	cogkernel\
	cogkernel_autognosis\

OFILES=

BIN=$PLAN9/bin

<$PLAN9/src/mkone

cogkernel: src/cogkernel.c
	6c -o cogkernel.6 src/cogkernel.c
	6l -o $target cogkernel.6

cogkernel_autognosis: src/cogkernel_autognosis.c
	6c -o cogkernel_autognosis.6 src/cogkernel_autognosis.c
	6l -o $target cogkernel_autognosis.6

clean:V:
	rm -f *.6 *.out cogkernel cogkernel_autognosis
